// Prisma schema for Mess Finder platform
// SQLite datasource

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      String   @default("SEEKER") // SEEKER | OWNER | ADMIN
  status    String   @default("ACTIVE") // ACTIVE | PENDING | SUSPENDED
  avatar    String?
  preferredAreas String? // comma-separated
  commissionRate Float @default(5.0) // platform commission % for owners
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messes    Mess[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]
  payments  Payment[]
  expenses  Expense[]
}

model Mess {
  id          String   @id @default(cuid())
  name        String
  description String
  address     String
  area        String
  city        String
  lat         Float
  lng         Float
  type        String   // STUDENT_MALE | STUDENT_FEMALE | FAMILY
  rentFrom    Int      // taka/month
  rentTo      Int
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  verified    Boolean  @default(false)
  published   Boolean  @default(true)
  featured    Boolean  @default(false)
  reported    Boolean  @default(false)
  reportReason String?
  images      String   // JSON array of URLs
  facilities  String   // JSON array of facility keys
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  rooms       Room[]
  reviews     Review[]
  favorites   Favorite[]
  expenses   Expense[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id        String   @id @default(cuid())
  number    String
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  seats     Seat[]
}

model Seat {
  id        String   @id @default(cuid())
  number    String
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  rent      Int
  type      String   // SINGLE | SHARED
  status    String   @default("AVAILABLE") // AVAILABLE | PENDING | BOOKED | MAINTENANCE
  bookings  Booking[]
}

model Booking {
  id          String   @id @default(cuid())
  reference   String   @unique
  seatId      String
  seat        Seat     @relation(fields: [seatId], references: [id])
  messId      String
  seekerId    String
  seeker      User     @relation(fields: [seekerId], references: [id])
  moveInDate  DateTime
  duration    String   // e.g. "6 months"
  durationMonths Int   @default(6)
  message     String?
  status      String   @default("PENDING") // PENDING | CONFIRMED | REJECTED | WAITLISTED | COMPLETED | CHECKED_OUT
  rejectReason String?
  securityDeposit Int  @default(0) // advance/security money
  agreedRent  Int      @default(0) // monthly rent agreed
  checkOutDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[]
}

// Monthly rent payments from seekers
model Payment {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seekerId    String
  seeker      User     @relation(fields: [seekerId], references: [id])
  messId      String
  amount      Int      // taka
  type        String   // RENT | DEPOSIT | UTILITY | LATE_FEE | OTHER
  month       String   // "2026-01" format — which month this payment is for
  dueDate     DateTime
  paidDate    DateTime?
  status      String   @default("DUE") // DUE | PAID | OVERDUE | PARTIAL
  method      String?  // CASH | BKASH | NAGAD | BANK
  reference   String?  // transaction reference
  note        String?
  createdAt   DateTime @default(now())
}

// Owner expenses (utilities, maintenance, salary, etc.)
model Expense {
  id          String   @id @default(cuid())
  messId      String
  mess        Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  category    String   // UTILITY | MAINTENANCE | SALARY | FOOD | SECURITY | CLEANING | MARKETING | TAX | OTHER
  amount      Int      // taka
  description String
  date        DateTime
  recurring   Boolean  @default(false) // monthly recurring?
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String
  ownerReply String?
  createdAt DateTime @default(now())
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messId String
  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)

  @@unique([userId, messId])
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  reason    String?
  createdAt DateTime @default(now())
}
